NODE_ENV=development
PORT=4000

# Postgres (Render) — ?sslmode=require is mandatory on Render.
DATABASE_URL="postgresql://USER:PASS@HOST.oregon-postgres.render.com/DB?sslmode=require"
DIRECT_URL="postgresql://USER:PASS@HOST.oregon-postgres.render.com/DB?sslmode=require"

# Redis (Render Key Value / Upstash)
REDIS_URL="redis://USER:PASS@HOST:PORT"

# JWT — generate two long random secrets (openssl rand -hex 32)
JWT_ACCESS_SECRET="change-me-32+chars"
JWT_REFRESH_SECRET="change-me-different-32+chars"
JWT_ACCESS_TTL="15m"
JWT_REFRESH_TTL="30d"

# Brevo
BREVO_API_KEY=""
BREVO_SENDER_EMAIL="noreply@mail.yourdomain.com"
BREVO_SENDER_NAME="DGC"

# OAuth
GOOGLE_CLIENT_ID=""
APPLE_CLIENT_ID=""

# Cloudinary (single URL form)
CLOUDINARY_URL="cloudinary://KEY:SECRET@CLOUD_NAME"

CORS_ORIGIN="*"
